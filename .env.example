# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskapp_dev
DB_USER=postgres
DB_PASSWORD=change_me

# Optional direct Prisma connection string override
# DATABASE_URL=postgresql://postgres:change_me@localhost:5432/taskapp_dev

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3004
API_PREFIX=/api

# CORS / hosts
FRONTEND_URL=http://localhost:5173
DEV_HOST=http://localhost:5173
PROD_HOST=https://your-backend-domain.com

# ============================================
# BETTER AUTH
# ============================================
BETTER_AUTH_SECRET=replace_with_secure_secret
BETTER_AUTH_URL=http://localhost:3004
BETTER_AUTH_BASE_PATH=/api/auth/handler

# Optional environment-specific Better Auth URLs
BETTER_AUTH_URL_DEV=http://localhost:3004
BETTER_AUTH_URL_PROD=https://your-backend-domain.com

# ============================================
# MAILER (PASSWORD RESET)
# ============================================
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
MAIL_FROM="TaskApp <no-reply@example.com>"

# ============================================
# SECURITY BASELINE (RATE LIMIT)
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=180
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=20
