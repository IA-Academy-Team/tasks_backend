{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "npx prisma generate && nodemon --watch src --ext ts --exec \"tsx src/index.ts\"",
    "dev:swagger": "npm run swagger:generate && npm run dev",
    "debug": "node --inspect=9229 --enable-source-maps --import tsx src/index.ts",
    "debug:swagger": "npm run swagger:generate && npm run debug",
    "build": "npx prisma generate && tsc -p tsconfig.build.json",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "swagger": "npm run swagger:generate",
    "swagger:guide": "npm run swagger:generate && node --import tsx src/shared/scripts/generate-swagger-endpoint-guide.ts",
    "db:seed": "node --import tsx prisma/seeds.ts",
    "swagger:generate": "node --import tsx src/shared/scripts/generate-swagger.ts",
    "test:endpoints:live": "node --import tsx src/shared/scripts/test-endpoints-live.ts",
    "test:endpoints:vitest": "vitest run src/shared/tests/live-endpoints.test.ts",
    "test": "npm run test:endpoints:vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.5.3",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.5.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.3.3",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "eslint": "^9.38.0",
    "globals": "^16.4.0",
    "morgan": "^1.10.1",
    "nodemon": "^3.1.14",
    "prisma": "^7.4.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1"
  }
}
